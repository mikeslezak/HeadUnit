{
  "palette": {
    "bg": "#0a0a0f",
    "text": "#39ff14",
    "primary": "#00f0ff",
    "accent": "#ff00ff",
    "cardBg": "#00141a",
    "success": "#39ff14",
    "error": "#ff003c",
    "warning": "#ffae00"
  },
  "typography": {
    "fontFamily": "Orbitron",
    "fontFile": "fonts/Orbitron-Regular.ttf",
    "fontSize": 24
  },
  "layout": {
    "pageMargin": 18,
    "gap": 15
  },
  "button": {
    "width": 360,
    "height": 66,
    "radius": 15,
    "padH": 24,
    "padV": 15,
    "gap": 12,
    "iconSize": 30,
    "dur": 140,
    "pressScale": 0.95,
    "bg": "#00141a",
    "fg": "#39ff14",
    "border": "#00f0ff",
    "borderWidth": 2
  },
  "miniPlayer": {
    "height": 90,
    "expandedHeight": 400,
    "bg": "#0a0a0f",
    "bgOpacity": 0.95,
    "borderWidth": 2,
    "artSize": 66,
    "artRadius": 8,
    "controlSize": 52,
    "controlSizeExpanded": 60,
    "playButtonSize": 80,
    "iconSize": 22,
    "iconSizeExpanded": 26,
    "playIconSize": 32,
    "controlSpacing": 20,
    "useGlow": true
  },
  "navbar": {
    "width": 138,
    "pad": 18,
    "iconSize": 84,
    "text": "#00f0ff",
    "bg": "#0a0a0f",
    "pressScale": 0.92
  },
  "icons": {
      "home": "icons/home_cyber.png",
      "music": "icons/music_cyber.png",
      "maps": "icons/maps_cyber.png",
      "settings": "icons/settings_cyber.png",
      "play": "icons/play_cyber.svg",
      "pause": "icons/pause_cyber.svg",
      "next": "icons/next_cyber.svg",
      "previous": "icons/previous_cyber.svg",
      "search": "icons/search_cyber.svg",
      "phone": "icons/phone_cyber.png",
      "messages": "icons/messages_cyber.png",
      "contacts": "icons/contacts_cyber.png",
      "tidal": "icons/tidal_cyber.svg",
      "spotify": "icons/spotify_cyber.svg",
      "radio": "icons/radio_cyber.png",
      "podcasts": "icons/podcast_cyber.png",
      "climate": "icons/climate_cyber.png",
      "vehicle": "icons/vehicle_cyber.svg",
      "camera": "icons/camera_cyber.png",
      "weather": "icons/weather_cyber.svg",
      "tuning": "icons/tuning_cyber.svg"
  },
  "overlay": {
    "type": "grid",
    "spacing": 21,
    "opacity": 0.10,
    "color": "#00f0ff"
  },
  "splash": {
    "logo": "logo.svg",
    "bg": "#000000",
    "color": "#00f0ff",
    "glow": "#00f0ff66",
    "animStyle": "typewriter",
    "logoAnim": "glow",
    "logoColorMode": "colorize",
    "primaryText": "CHEVROLET",
    "secondaryText": "AMERICA'S HEARTBEAT",
    "logoSize": 330,
    "titleSize": 60,
    "subtitleSize": 27,
    "charDuration": 80,
    "holdDuration": 2500,
    "fadeOutDuration": 1200,
    "scanlines": true,
    "scanlineOpacity": 0.08,
    "scanlineSpacing": 6,
    "useGlow": true,
    "glowIntensity": 18
  }
}
