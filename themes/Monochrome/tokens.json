{
  "palette": {
    "bg": "#0C0C0C",
    "text": "#E0E0E0",
    "primary": "#FFFFFF",
    "accent": "#808080",
    "cardBg": "#161616",
    "success": "#AAAAAA",
    "error": "#CCCCCC",
    "warning": "#999999"
  },
  "typography": {
    "fontFamily": "Inter Display",
    "fontFile": "fonts/InterDisplay-Regular.ttf",
    "fontSize": 18
  },
  "layout": {
    "pageMargin": 20,
    "gap": 16
  },
  "button": {
    "width": 360,
    "height": 56,
    "radius": 6,
    "padH": 24,
    "padV": 14,
    "gap": 12,
    "iconSize": 24,
    "dur": 160,
    "pressScale": 0.97,
    "bg": "#1A1A1A",
    "fg": "#E0E0E0",
    "border": "#333333",
    "borderWidth": 1
  },
  "navbar": {
    "width": 120,
    "pad": 16,
    "iconSize": 72,
    "text": "#FFFFFF",
    "bg": "#0C0C0C",
    "pressScale": 0.95
  },
  "icons": {
    "home": "icons/home_mono.svg",
    "music": "icons/music_mono.svg",
    "maps": "icons/maps_mono.svg",
    "settings": "icons/settings_mono.svg",
    "play": "icons/play_mono.svg",
    "pause": "icons/pause_mono.svg",
    "next": "icons/next_mono.svg",
    "previous": "icons/previous_mono.svg",
    "search": "icons/search_mono.svg",
    "phone": "icons/phone_mono.svg",
    "messages": "icons/messages_mono.svg",
    "contacts": "icons/contacts_mono.svg",
    "vehicle": "icons/vehicle_mono.svg",
    "weather": "icons/weather_mono.svg",
    "tuning": "icons/tuning_mono.svg",
    "tidal": "icons/tidal_mono.svg",
    "spotify": "icons/spotify_mono.svg",
    "radio": "icons/radio_mono.svg",
    "podcasts": "icons/podcasts_mono.svg",
    "climate": "icons/climate_mono.svg",
    "camera": "icons/camera_mono.svg"
  },
  "miniPlayer": {
    "height": 80,
    "expandedHeight": 400,
    "bg": "#111111",
    "bgOpacity": 0.98,
    "borderWidth": 1,
    "artSize": 56,
    "artRadius": 4,
    "controlSize": 44,
    "controlSizeExpanded": 56,
    "playButtonSize": 64,
    "iconSize": 20,
    "iconSizeExpanded": 24,
    "playIconSize": 28,
    "controlSpacing": 16,
    "useGlow": false
  },
  "shape": {
    "radius": 6,
    "borderWidth": 1
  },
  "motion": {
    "duration": 200,
    "easing": "OutCubic"
  },
  "overlay": {
    "type": "none",
    "spacing": 0,
    "opacity": 0,
    "color": "#FFFFFF"
  },
  "splash": {
    "video": "splash.webm",
    "logo": "logo.svg",
    "bg": "#000000",
    "color": "#C8C8C8",
    "glow": "#00000000",
    "animStyle": "fadeIn",
    "logoAnim": "static",
    "logoColorMode": "colorize",
    "primaryText": "CHEVROLET",
    "secondaryText": "BY GENERAL MOTORS",
    "logoSize": 300,
    "titleSize": 44,
    "subtitleSize": 14,
    "letterSpacing": 16,
    "subtitleLetterSpacing": 8,
    "charDuration": 0,
    "fadeInLogoDuration": 2000,
    "fadeInTextDelay": 600,
    "fadeInTextDuration": 1500,
    "fadeInSubtitleDelay": 500,
    "fadeInSubtitleDuration": 1200,
    "fadeInLineDelay": 300,
    "fadeInLineDuration": 1000,
    "holdDuration": 2500,
    "fadeOutDuration": 2000,
    "scanlines": false,
    "scanlineOpacity": 0,
    "scanlineSpacing": 4,
    "useGlow": false,
    "glowIntensity": 0,
    "useVignette": true,
    "useLine": true,
    "lineColor": "#2A2A2A"
  }
}
